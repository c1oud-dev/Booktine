# 환경변수 템플릿 파일
# 이 파일은 Git에 포함되며, 어떤 환경변수가 필요한지 보여주는 템플릿 역할을 한다.
# 실제 개발 시 이 파일을 복사해 .env 파일을 만들고 값을 채워 넣으면 된다.

# 백엔드 API 서버 주소
# - 로컬 개발: http://localhost:8080
# - 운영(HTTPS 프론트): HTTPS로 접근 가능한 백엔드 오리진을 사용해야 한다.
#   예: https://api.booktine.cloud 또는 CloudFront/리버스 프록시로 연결된 HTTPS API 주소
VITE_API_BASE_URL=http://localhost:8080